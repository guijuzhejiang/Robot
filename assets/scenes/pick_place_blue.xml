<mujoco model="pick_place_blue">
  <!--
    PickPlaceBlue scene:
      - SO-ARM101 follower arm (from mujoco_menagerie/robotstudio_so101)
      - 1 red cube (4cm) + 1 blue cube (4cm) — distractor + target
      - 1 plate (cylindrical, 12cm diameter × 1cm height)
      - Front cam + wrist cam (wrist cam already in so101.xml)
      - Hemispherical sky light + 3 point lights (DR-randomizable)

    Body-origin convention:
      cube body origin = geom center (so xpos == geom center)
      plate body origin = geom center of base disc
    Free joints on cubes and plate let DR randomize pose via qpos.
  -->
  <!--
    Mesh resolution:
      The included so101.xml sets `meshdir="assets"` relative to itself.
      MuJoCo resolves it relative to THIS parent file's location instead, so we
      provide a symlink at ./assets that points into the menagerie SO101 mesh dir.
      Symlink: assets/scenes/assets -> ../menagerie/robotstudio_so101/assets
  -->
  <option integrator="implicitfast" timestep="0.002" cone="elliptic" iterations="10"
          ls_iterations="20" impratio="10"/>

  <!-- Pull in SO-ARM101 defaults, assets, and worldbody arm tree -->
  <include file="../menagerie/robotstudio_so101/so101.xml"/>

  <statistic center="0.0 0.0 0.15" extent="0.6"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <asset>
    <!-- Sky + ground textures (kept simple; DR module can replace at runtime) -->
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0"
             width="512" height="3072"/>
    <texture type="2d" name="tablecloth" builtin="checker" mark="cross"
             rgb1="0.85 0.85 0.85" rgb2="0.65 0.65 0.65" markrgb="0.9 0.9 0.9"
             width="300" height="300"/>
    <material name="tablecloth" texture="tablecloth" texrepeat="6 6" reflectance="0.05"/>
    <material name="red_cube"  rgba="0.85 0.10 0.10 1"/>
    <material name="blue_cube" rgba="0.10 0.20 0.85 1"/>
    <material name="plate"     rgba="0.95 0.95 0.95 1"/>
  </asset>

  <worldbody>
    <!-- Three DR-randomizable point lights -->
    <light name="light0" pos="0.3  0.3 1.0" dir="-0.2 -0.2 -1" diffuse="0.7 0.7 0.7"/>
    <light name="light1" pos="-0.3 0.3 1.0" dir=" 0.2 -0.2 -1" diffuse="0.4 0.4 0.4"/>
    <light name="light2" pos="0.0 -0.3 1.0" dir=" 0   0.2 -1" diffuse="0.4 0.4 0.4"/>

    <!-- Table: 60×60×2cm, top at z=0; SO101 base mounts at z=0 -->
    <geom name="table" type="box" size="0.30 0.30 0.01" pos="0 0 -0.01"
          material="tablecloth" friction="1 0.005 0.0001" contype="1" conaffinity="1"/>

    <!-- Front camera: 30cm in front of base, 30° downward tilt -->
    <camera name="front" pos="0.35 0.0 0.30" xyaxes="0 -1 0  -0.5 0 0.866"
            resolution="640 480" fovy="55"/>

    <!-- Red cube (distractor): free body, origin = geom center -->
    <body name="red_cube" pos="0.18 -0.08 0.02">
      <freejoint name="red_cube_freejoint"/>
      <inertial pos="0 0 0" mass="0.05" diaginertia="1.33e-5 1.33e-5 1.33e-5"/>
      <geom name="red_cube_geom" type="box" size="0.02 0.02 0.02" material="red_cube"
            friction="1 0.005 0.0001" condim="4" priority="1"/>
    </body>

    <!-- Blue cube (target): free body, origin = geom center -->
    <body name="blue_cube" pos="0.18  0.08 0.02">
      <freejoint name="blue_cube_freejoint"/>
      <inertial pos="0 0 0" mass="0.05" diaginertia="1.33e-5 1.33e-5 1.33e-5"/>
      <geom name="blue_cube_geom" type="box" size="0.02 0.02 0.02" material="blue_cube"
            friction="1 0.005 0.0001" condim="4" priority="1"/>
    </body>

    <!-- Plate: cylinder, 6cm radius × 0.5cm half-height. Origin = geom center -->
    <body name="plate" pos="0.28 0.0 0.005">
      <freejoint name="plate_freejoint"/>
      <inertial pos="0 0 0" mass="0.15" diaginertia="3e-4 3e-4 5e-4"/>
      <geom name="plate_geom" type="cylinder" size="0.06 0.005" material="plate"
            friction="1 0.005 0.0001" condim="4"/>
    </body>
  </worldbody>

  <keyframe>
    <!-- Home pose: arm ready, ee at approx [0.24, 0, 0.14] above table center.
         qpos = 6 arm + 7 (red free) + 7 (blue free) + 7 (plate free) = 27.
         ctrl = 6 actuators. Last ctrl value 0.5 = gripper somewhat open. -->
    <key name="home"
         qpos="0 -1.8 1.5 0.5 0 0.5
               0.18 -0.08 0.02 1 0 0 0
               0.18  0.08 0.02 1 0 0 0
               0.28  0.00 0.005 1 0 0 0"
         ctrl="0 -1.8 1.5 0.5 0 0.5"/>
  </keyframe>
</mujoco>
