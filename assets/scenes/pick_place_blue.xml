<mujoco model="pick_place_blue">
  <!--
    PickPlace scene rebuilt on top of pick-101's SO-101 model
    (ggand0/pick-101 lift_cube.xml). Single 3 cm red cube + freejoint
    white plate.

    Why this model and not menagerie's so101.xml:
      - so101_new_calib.xml adds graspframe + per-fingertip sites + 1.25 mm
        finger_pad collision geoms that produce stable multi-contact grasps.
      - Top-down keyframe sits at wrist_flex = wrist_roll = pi/2 so the
        gripper points straight down; the scripted policy locks joints
        [3, 4] and lets DLS IK adjust only base/shoulder/elbow for XYZ.

    Path:
      include "../so101_pick101/so101_new_calib.xml" → its <compiler>
      meshdir="assets" resolves to assets/so101_pick101/assets/, where
      the STL meshes live.
  -->
  <include file="../so101_pick101/so101_new_calib.xml"/>

  <option timestep="0.002" gravity="0 0 -9.81" noslip_iterations="3"
          impratio="10" cone="elliptic"/>

  <default>
    <geom solref="0.001 1" solimp="0.99 0.99 0.001"/>
  </default>

  <statistic center="0.0 0.0 0.15" extent="0.6"/>

  <visual>
    <headlight diffuse="0.3 0.3 0.3" ambient="0.15 0.15 0.15" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <!-- Offscreen framebuffer at 1080p so envs created with
         img_height/img_width up to 1920x1080 render without an
         "Image width N > framebuffer width" error. Default render is
         480x640; this just sets the upper bound. -->
    <global azimuth="120" elevation="-20" offwidth="1920" offheight="1080"/>
    <map znear="0.005"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.40 0.42 0.45" rgb2="0.10 0.10 0.12"
             width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge"
             rgb1="0.20 0.30 0.40" rgb2="0.10 0.20 0.30" markrgb="0.8 0.8 0.8"
             width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true"
              texrepeat="5 5" reflectance="0.2"/>
    <material name="table_top" rgba="0.30 0.30 0.32 1" reflectance="0.02"/>
    <material name="red_cube"  rgba="0.85 0.10 0.10 1"/>
    <material name="plate"     rgba="0.95 0.95 0.95 1"/>
  </asset>

  <worldbody>
    <!-- DR-randomizable point lights (sim/randomization/lighting.py keys
         these names: light0/light1/light2). -->
    <light name="light0" pos="0.3  0.3 1.0" dir="-0.2 -0.2 -1" diffuse="0.4 0.4 0.4"/>
    <light name="light1" pos="-0.3 0.3 1.0" dir=" 0.2 -0.2 -1" diffuse="0.25 0.25 0.25"/>
    <light name="light2" pos="0.0 -0.3 1.0" dir=" 0   0.2 -1" diffuse="0.25 0.25 0.25"/>

    <!-- Workshop floor below the table (visual only, no contacts) -->
    <geom name="floor" type="plane" size="2 2 0.05" pos="0 0 -0.75"
          material="groundplane" contype="0" conaffinity="0"/>

    <!-- 80×80×4 cm table, surface at z=0, slightly offset so workspace sits
         near center (arm base at origin, cubes/plate ~x∈[0.18, 0.30]). -->
    <geom name="table_top" type="box" size="0.40 0.40 0.02" pos="0.14 0 -0.02"
          material="table_top" friction="1 0.005 0.0001" contype="1" conaffinity="1"/>
    <geom name="leg_pp" type="box" size="0.02 0.02 0.355" pos=" 0.52  0.38 -0.395" rgba="0.25 0.18 0.12 1"/>
    <geom name="leg_pn" type="box" size="0.02 0.02 0.355" pos=" 0.52 -0.38 -0.395" rgba="0.25 0.18 0.12 1"/>
    <geom name="leg_np" type="box" size="0.02 0.02 0.355" pos="-0.24  0.38 -0.395" rgba="0.25 0.18 0.12 1"/>
    <geom name="leg_nn" type="box" size="0.02 0.02 0.355" pos="-0.24 -0.38 -0.395" rgba="0.25 0.18 0.12 1"/>

    <!-- Front camera (sim/randomization/camera_pose.py jitters this). -->
    <camera name="front" pos="0.55 -0.35 0.5" xyaxes="0.707 0.707 0  -0.476 0.476 0.740"
            resolution="640 480" fovy="58"/>

    <!-- 3 cm red cube — single target object. condim=4 + priority=1 lets
         the finger pads (priority 0) inherit the cube's higher-fidelity
         friction model on contact. -->
    <body name="red_cube" pos="0.18 -0.04 0.015">
      <freejoint name="red_cube_freejoint"/>
      <inertial pos="0 0 0" mass="0.03" diaginertia="6.75e-6 6.75e-6 6.75e-6"/>
      <geom name="red_cube_geom" type="box" size="0.015 0.015 0.015"
            material="red_cube" friction="0.5 0.05 0.001" condim="4" priority="1"/>
    </body>

    <!-- White plate: 6 cm radius × 0.2 cm half-height. Freejoint so DR can
         randomize pose; mass=0.15 kg keeps it stable under cube drop. -->
    <body name="plate" pos="0.28 0.04 0.002">
      <freejoint name="plate_freejoint"/>
      <inertial pos="0 0 0" mass="0.15" diaginertia="3e-4 3e-4 5e-4"/>
      <geom name="plate_geom" type="cylinder" size="0.06 0.002"
            material="plate" friction="1 0.005 0.0001" condim="4"/>
    </body>
  </worldbody>

  <keyframe>
    <!--
      Top-down home pose, matching pick-101 test_topdown_pick.py exactly:
        shoulder_pan = 0
        shoulder_lift = 0
        elbow_flex = 0
        wrist_flex = pi/2     ← bends wrist so fixed_jaw points DOWN
        wrist_roll = pi/2     ← rotates fingers to spread along Y
        gripper     = 0.3     ← jaws slightly closed
      qpos layout: arm(6) + red_cube(3 pos + 4 quat) + plate(3 pos + 4 quat)
    -->
    <key name="home"
         qpos="0 0 0 1.5707963 1.5707963 0.3
               0.18 -0.04 0.015 1 0 0 0
               0.28  0.04 0.002 1 0 0 0"
         ctrl="0 0 0 1.5707963 1.5707963 0.3"/>
  </keyframe>
</mujoco>
